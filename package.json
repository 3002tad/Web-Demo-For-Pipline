{
  "name": "markethub-demo",
  "version": "1.0.0",
  "description": "MarketHub demo with Express API, MongoDB, and preserved behavior tracking SDK output.",
  "main": "backend/src/server.js",
  "scripts": {
    "start": "node backend/src/server.js",
    "dev": "nodemon backend/src/server.js",
    "worker": "node backend/src/worker.js",
    "adapter": "node tracking-adapter/src/index.js",
    "adapter:dev": "nodemon tracking-adapter/src/index.js",
    "bot": "node behavior-bot/src/index.js",
    "rabbitmq:setup": "scripts\\setup-rabbitmq-local.bat",
    "rabbitmq:check": "scripts\\check-rabbitmq-local.bat",
    "seed": "node backend/src/seeds/seed.js",
    "seed:users": "node backend/src/seeds/seed-users.js"
  },
  "dependencies": {
    "amqplib": "^2.0.1",
    "axios": "^1.16.1",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.5",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.9",
    "playwright": "^1.60.0"
  }
}
