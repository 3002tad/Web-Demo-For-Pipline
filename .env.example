# Single env file for: npm run dev | worker | adapter
# Copy: copy .env.example .env

# --- Web API ---
PORT=3000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:3000

MONGO_URI=mongodb://localhost:27017/markethub_demo

# Lap1 k3s tracking-api NodePort (behavior SDK → /track)
TRACKING_FORWARD_URL=http://lap1.bigdata.ts.net:31000/track
TRACKING_DEBUG_STORE=true

JWT_SECRET=change-me-demo-secret
JWT_EXPIRES_IN=7d
AUTH_COOKIE_NAME=markethub_token
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# --- RabbitMQ (local on Lap2; shared by API, worker, adapter) ---
RABBITMQ_URL=amqp://markethub:markethub123@localhost:5672
RABBITMQ_EXCHANGE=ecommerce.events
RABBITMQ_EXCHANGE_TYPE=topic
RABBITMQ_DLX=ecommerce.events.dlx

# Order worker queue
RABBITMQ_ORDER_QUEUE=webdemo.order-processing
RABBITMQ_ORDER_BINDING_KEY=order.created
RABBITMQ_ORDER_DLQ=webdemo.order-processing.dlq
RABBITMQ_MANAGE_LOCAL=true
RABBITMQ_EMBED_WORKER=false
ORDER_PROCESSING_STEP_DELAY_MS=0
RABBITMQ_PUBLISH_CONFIRM_TIMEOUT_MS=3000

# Tracking adapter queue (business events → Lap1 ingest)
RABBITMQ_ADAPTER_QUEUE=tracking.adapter.business-events
RABBITMQ_ADAPTER_BINDING_KEYS=order.*,payment.*,inventory.*
RABBITMQ_ADAPTER_PREFETCH=10
RABBITMQ_ADAPTER_DLQ=tracking.adapter.business-events.dlq

# Lap1 ingest (must match k3s secret TRACKING_INGEST_API_KEY)
TRACKING_INGEST_URL=http://lap1.bigdata.ts.net:31000
TRACKING_INGEST_PATH=/api/ingest/business-events
TRACKING_INGEST_API_KEY=demo-ingest-key-change-me
TRACKING_INGEST_TIMEOUT_MS=10000

ADAPTER_SOURCE=web_demo_rabbitmq_adapter
TENANT_ID=demo_store
BATCH_SIZE=10
BATCH_FLUSH_INTERVAL_MS=3000
MAX_DELIVERY_RETRIES=3
DEBUG=false

# --- Behavior bot (Playwright/Edge local user simulation) ---
BOT_BASE_URL=http://localhost:3000
BOT_USERS=20
BOT_CONCURRENCY=3
BOT_HEADLESS=true
BOT_EDGE_PATH=C:/Program Files (x86)/Microsoft/Edge/Application/msedge.exe
BOT_MIN_DELAY_MS=500
BOT_MAX_DELAY_MS=2500
BOT_LOGIN_RATE=0.30
BOT_SEARCH_RATE=0.65
BOT_FILTER_RATE=0.40
BOT_PRODUCT_VIEW_RATE=0.80
BOT_BANNER_VIEW_RATE=0.55
BOT_BANNER_CLICK_RATE=0.18
BOT_ADD_TO_CART_RATE=0.35
BOT_CHECKOUT_START_RATE=0.20
BOT_PURCHASE_RATE=0.12
BOT_CART_ABANDON_RATE=0.08
BOT_SCROLL_RATE=0.90
BOT_USE_PERSONA_RATES=false
BOT_REPORT_PATH=output/behavior-bot/latest-report.json
